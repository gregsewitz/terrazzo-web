# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# enrichment logs
enrich-log*.txt

# large cache / pipeline intermediate files
signal-embeddings-cache.json
signal-corpus.json
signal-dimensions.json
signal-singletons.json
silhouette-sweep.json
/signal-clusters.json

# cluster audit one-off outputs
cluster-*-audit-*.csv
cluster-*-audit-*.json

# cluster backup snapshots
*.backup.json
.env*.local

# skill cache (regenerated locally)
*.skill
