# ─── Terrazzo Web — Environment Variables ────────────────────────────────────
#
# Copy this file to .env.local and fill in the values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enable additional features but have graceful fallbacks.

# ── Core Infrastructure [REQUIRED] ───────────────────────────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/terrazzo

# ── Auth & Security [REQUIRED] ───────────────────────────────────────────────

ADMIN_SECRET=your-admin-secret-here
CRON_SECRET=your-cron-secret-here

# ── Supabase [REQUIRED] ─────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── AI Providers [REQUIRED] ─────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Override default Claude model (optional, defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Google [REQUIRED] ───────────────────────────────────────────────────────

GOOGLE_PLACES_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ── Text-to-Speech [REQUIRED] ───────────────────────────────────────────────

ELEVENLABS_API_KEY=your-elevenlabs-key

# ── Nylas Email Integration [OPTIONAL] ──────────────────────────────────────
# Required for email reservation scanning feature

# NYLAS_API_KEY=your-nylas-api-key
# NYLAS_CLIENT_ID=your-nylas-client-id
# NYLAS_REDIRECT_URI=http://localhost:3000/api/auth/nylas/callback
# NYLAS_WEBHOOK_SECRET=your-nylas-webhook-secret
# NYLAS_WEBHOOK_URL=https://www.terrazzo.travel/api/email/webhooks/nylas

# ── Enrichment Pipeline [OPTIONAL] ──────────────────────────────────────────
# Required for place intelligence enrichment via Railway worker

# PIPELINE_WORKER_URL=https://your-pipeline-worker.up.railway.app
# PIPELINE_WEBHOOK_SECRET=your-pipeline-webhook-secret

# ── Web Scraping [OPTIONAL] ────────────────────────────────────────────────
# Required for URL-based import feature

# FIRECRAWL_API_KEY=your-firecrawl-key

# ── Redis Cache [OPTIONAL] ──────────────────────────────────────────────────
# Falls back to in-memory cache if not set

# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Demo Mode [OPTIONAL] ───────────────────────────────────────────────────
# Set to 'false' to disable demo data in development

# NEXT_PUBLIC_DEMO_DATA=true
